# Copie para .env e ajuste os valores.
NODE_ENV=development
PORT=8443

# PostgreSQL (RNF013)
DATABASE_URL=postgres://idnotes:idnotes@localhost:5432/idnotes

# Redis (RNF006 - rate limiting)
REDIS_URL=redis://localhost:6379

# RNF001 - segredo do HMAC-SHA256 da idKey (gere algo forte e único)
IDKEY_HMAC_SECRET=troque-este-segredo-em-producao
# RNF005 - custo do bcrypt do hash persistido
BCRYPT_ROUNDS=12

# Sessão JWT (RF004 no app)
JWT_SECRET=troque-este-jwt-em-producao
JWT_EXPIRES_IN=30d

# RNF006 - 3 solicitações por e-mail a cada 10 minutos
RATE_LIMIT_MAX=3
RATE_LIMIT_WINDOW_SECONDS=600

# RNF004 - HTTPS/TLS
# TLS_ENABLED=true serve HTTPS direto (precisa de TLS_KEY_PATH/TLS_CERT_PATH).
# Padrão: TLS terminado por proxy reverso (TLS_ENABLED=false, TLS_BEHIND_PROXY=true).
TLS_ENABLED=false
TLS_BEHIND_PROXY=true
TLS_KEY_PATH=./certs/key.pem
TLS_CERT_PATH=./certs/cert.pem
